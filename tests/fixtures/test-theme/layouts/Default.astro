---
interface Props {
  /** Titre de la page */
  title: string;
  /** Description pour le SEO */
  description?: string;
}

const { title, description } = Astro.props;
---

<html>
  <head>
    <title>{title}</title>
    {description && <meta name="description" content={description} />}
  </head>
  <body>
    <slot />
  </body>
</html>
